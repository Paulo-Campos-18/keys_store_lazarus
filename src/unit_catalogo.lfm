  object QueryCatalogo: TZQuery
    Connection = CnnCatalogo
    SQL.Strings = (
      'select g.id,g.name,g.studio,g.price, img.image_byte'
      'from games g,images img'
      'where img.game_id = g.id and'
      'img.is_cover = 1 and'
      'g.deleted = 0;'
